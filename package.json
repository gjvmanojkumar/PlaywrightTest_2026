{
  "name": "newproject",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "allureReport": "allure serve",
    "clean:reports": "rm -rf allure-report allure-results && mkdir -p allure-report allure-results",
    "generate:reports": "npx allure generate ./allure-results --clean",
    "open-reports": "npx allure open ./allure-report",
    "pretest": "npm run clean:reports",
    "posttest": "npm run generate:reports && npm run open-reports",
    "execute:script": "npx playwright test transferOptionsTest.spec.ts --project=chromium",
    "test": "npm run execute:script || npm rum posttest",
    "web_regression": "npx playwright test",
    "letsShop_PlaceOrder": "npx playwright test OrderProductTest",
    "bookAnEvent_test": "npx playwright test CreateAnEventTest",
    "groupTicketBooking_test": "npx playwright test GroupTicketBooking",
    "singleEventWithRefund_test": "npx playwright test SingleEventWithRefund",
    "AzureTestsRegression": "npx playwright test --config=playwright.service.config.ts --workers=4"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@azure/identity": "^4.13.1",
    "@azure/playwright": "^1.1.6",
    "@playwright/test": "^1.58.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^25.9.1",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.4.5",
    "csv-parse": "^6.1.0",
    "luxon": "^3.7.2",
    "mkdirp": "^3.0.1",
    "rimraf": "^6.1.2"
  }
}
